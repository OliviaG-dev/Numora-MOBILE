# Copy to `.env.local`. Expo exposes `EXPO_PUBLIC_*` to the JS bundle.
#
# Web (browser on same machine):
#   EXPO_PUBLIC_API_URL=http://localhost:3000
#
# Physical device (Expo Go) — use your PC LAN IP:
#   EXPO_PUBLIC_API_URL=http://192.168.1.20:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Temporaire : pas d'écran de connexion (lectures en mémoire locale).
# EXPO_PUBLIC_SKIP_AUTH=true
